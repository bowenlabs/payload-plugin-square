# Payload
PAYLOAD_SECRET=your-payload-secret-here
DATABASE_URI=file:./dev.db

# Square server-side credentials
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SECRET=your-square-webhook-signature-key

# Square client-side (used by Web Payments SDK in the browser)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your-square-application-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
